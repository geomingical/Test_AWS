# WebSocket API endpoint — replace with your deployed API Gateway URL
# The current production endpoint (public, not a secret):
#   wss://ezi50tf1w1.execute-api.ap-northeast-1.amazonaws.com/prod
# Override locally via .env.local (gitignored). Production value lives in .env.production.
VITE_WS_ENDPOINT=wss://YOUR_API_ID.execute-api.ap-northeast-1.amazonaws.com/prod
